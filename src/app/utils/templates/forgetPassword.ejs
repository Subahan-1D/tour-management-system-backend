<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Forgot Password</title>
    <style>
      body {
        font-family: "Segoe UI", Arial, sans-serif;
        background: #f4f6f8;
        margin: 0;
        padding: 0;
        color: #333;
      }
      .email-wrapper {
        width: 100%;
        padding: 20px;
        background: #f4f6f8;
      }
      .email-container {
        max-width: 600px;
        margin: 0 auto;
        background: #ffffff;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
      }
      .header {
        background: linear-gradient(135deg, #007bff, #0056b3);
        padding: 20px;
        text-align: center;
      }
      .header h1 {
        color: #ffffff;
        font-size: 22px;
        margin: 0;
      }
      .body {
        padding: 30px;
      }
      .body h2 {
        color: #222;
        font-size: 20px;
        margin-bottom: 15px;
      }
      .body p {
        line-height: 1.6;
        font-size: 15px;
        margin: 10px 0;
      }
      .btn {
        display: inline-block;
        padding: 12px 24px;
        background: #007bff;
        color: #ffffff !important;
        text-decoration: none;
        border-radius: 6px;
        font-weight: 500;
        margin-top: 20px;
        transition: background 0.3s ease;
      }
      .btn:hover {
        background: #0056b3;
      }
      .footer {
        text-align: center;
        font-size: 12px;
        color: #888;
        padding: 15px;
        background: #f9f9f9;
        border-top: 1px solid #eee;
      }
      @media (max-width: 600px) {
        .body {
          padding: 20px;
        }
        .btn {
          width: 100%;
          text-align: center;
        }
      }
    </style>
  </head>
  <body>
    <div class="email-wrapper">
      <div class="email-container">
        <div class="header">
          <h1>Tour Management Apps</h1>
        </div>
        <div class="body">
          <h2>Password Reset Request</h2>
          <p>Hello <%= name %>,</p>
          <p>
            We received a request to reset your password. Click the button
            below to create a new password. This link will expire in 10
            minutes.
          </p>
          <a class="btn" href="<%= resetUILink %>">Reset Password</a>
          <p>
            If you didn’t request this, you can safely ignore this email. Your
            account is secure.
          </p>
        </div>
        <div class="footer">
          &copy; <%= new Date().getFullYear() %> Tour Management App. All rights
          reserved.
        </div>
      </div>
    </div>
  </body>
</html>
